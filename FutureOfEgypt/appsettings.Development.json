{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "TrackingSchedule": {
    "Enabled": false
  },
  "ProfileImages": {
    "StoragePath": "AppFiles/ProfileImages",
    "MaxSizeBytes": 2097152,
    "AllowedExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ]
  },
  "Cors": {
    "AllowAnyOriginInDevelopment": true
  },
  "PublicBaseUrl": {
    "Enabled": false,
    "BaseUrl": ""
  }
}
